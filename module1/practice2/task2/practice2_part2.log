journalctl -b --output=short-monotonic | awk -F'[][]' '$2+0 <= 20' >>practice2_${USER}_part2_result.log
find / -type f -name auth.log 2>/dev/null | xargs awk '{print $5, substr($0, index($0,$6))}' | sed 's/\[[0-9]\+\]://g' | sort >>practice2_${USER}_part2_result.log
find / -type f -name auth.log 2>/dev/null | xargs awk '{print $5}' | sed 's/\[[0-9]\+\]://g' | sort | uniq -c | sort -rn >>practice2_${USER}_part2_result.log
awk -F: '$7=="/usr/sbin/nologin" {print $1":"$3":"$4}' /etc/passwd | \                                                  
while IFS=":" read user uid gid; do
    primary=$(awk -F: -v gid=$gid '$3==gid {print $1}' /etc/group);
    additional=$(awk -F: -v user=$user '$4 ~ user {print $1}' /etc/group | paste -sd, -);
    if [ -n "$additional" ]; then groups="${primary},${additional}"; else groups=${primary}; fi;
    echo "$uid, $user, $groups";
done | sort -t, -k1,1nr >>practice2_${USER}_part2_result.log
dmesg | grep 'kernel'>>practice2_${USER}_part2_result.log
wc -l /var/log/kern.log>>practice2_${USER}_part2_result.log
awk '/Commandline:/ {cmd=$0} /Start-Date:/ {start=$0} /End-Date:/ {end=$0; print cmd " ; " start " ; " end}' /var/log/apt/history.log>>practice2_${USER}_part2_result.log
