cd ~
touch $USER_part3.log
mkdir -p D1/D2/D3
touch D1/D2/file.txt
echo "Hello, everyone\!\" > D1/D2/file.txt
ln -s D1/D2/file.txt D1/D2/D3/symlink_file.txt
ln D1/D2/file.txt D1/D2/D3/hardlink_file.txt
ls -l D1/D2/D3/
mv D1/D2/file.txt D1/
cat D1/D2/D3/symlink_file.txt
cat D1/D2/D3/hardlink_file.txt
rm -r D1/D2
find / -type f -size +20M > $USER_part3_gt20.log 2>/dev/null
ls -lh -- $(cat $USER_part3_gt20.log)
find ~ -type f -mtime -1
which find
file $(which find)
file /boot/initrd.img*